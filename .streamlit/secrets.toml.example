# Copy this file's contents into:
#   1. Local development: .streamlit/secrets.toml (same folder, this exact filename)
#   2. Streamlit Community Cloud: App settings > Secrets (paste as TOML)
#
# NEVER commit an actual API key to GitHub in this file — this is a template only.
# You don't need all four — the app quietly skips any source without a key.

SAFE_BROWSING_API_KEY = "your-google-safe-browsing-api-key-here"
VIRUSTOTAL_API_KEY = "your-virustotal-api-key-here"
URLSCAN_API_KEY = "your-urlscan-io-api-key-here"
MXTOOLBOX_API_KEY = "your-mxtoolbox-api-key-here"
